-- Day 17: Manufacturers with Loss-Making Drugs
-- Source: DataLemur (CVS Health SQL Interview)

-- Problem:
-- Identify manufacturers whose drugs resulted in losses.
-- For each manufacturer, return:
--   1. Number of drugs with losses
--   2. Total loss amount (absolute value)
-- Sort results by highest total loss.

-- Table Schema:
-- pharmacy_sales(product_id, units_sold, total_sales, cogs, manufacturer, drug)

-- Approach:
-- 1. Identify loss-making drugs where total_sales < cogs
-- 2. Group by manufacturer
-- 3. Count number of loss-making drugs per manufacturer
-- 4. Calculate total loss using (cogs - total_sales)
-- 5. Sort results in descending order of total loss

-- Concepts Used:
-- WHERE, GROUP BY, COUNT(), SUM(), ORDER BY

SELECT
  manufacturer,
  COUNT(*) AS drug_count,
  SUM(cogs - total_sales) AS total_loss
FROM pharmacy_sales
WHERE total_sales < cogs
GROUP BY manufacturer
ORDER BY total_loss DESC;
